PORT=4000

# Put your RapidAPI/Nokia key here (keep private, do not commit real secrets)
NAC_API_KEY=YOUR_RAPIDAPI_KEY

# Theme 5 — three APIs only. Use the SAME base host as RapidAPI/Postman code snippets for your subscription.
# If URL host and X-RapidAPI-Host do not match the listing you subscribed to, RapidAPI returns { "message": "API doesn't exists" }.
# Working example (global): host = network-as-code.p.rapidapi.com — not p-eu and not network-as-code.nokia.rapidapi.com unless that is your snippet.
NAC_SIM_SWAP_URL=https://network-as-code.p.rapidapi.com/passthrough/camara/v1/sim-swap/sim-swap/v0/check
# Number verification: live URL, or omit when using mock below.
NAC_NUMBER_VERIFY_URL=https://network-as-code.p.rapidapi.com/passthrough/camara/v1/number-verification/number-verification/v0/device-phone-number
# When true, skips HTTP and returns { "devicePhoneNumberVerified": true } (CAMARA verify shape) — use if /verify returns "API doesn't exists" on your RapidAPI listing.
NAC_MOCK_NUMBER_VERIFICATION=false
NAC_LOCATION_VERIFY_URL=https://network-as-code.p.rapidapi.com/location-verification/v1/verify
NAC_RAPIDAPI_HOST=network-as-code.p.rapidapi.com

# Optional request timeout (milliseconds)
NAC_TIMEOUT_MS=6500
NAC_CACHE_TTL_MS=15000

# Real Nokia only (default). Set NAC_USE_DEMO_NUMBERS=true to fake +999999910xx without calling the API.
NAC_USE_DEMO_NUMBERS=false

# If true, on unexpected errors return mock signals instead of 500 (not for live demos).
NAC_FALLBACK_MOCK_ON_ERROR=false

# --- QoD test only: npm run test:qod -- <sessionId> (see scripts/test-qod-extend.js)
# NAC_QOD_HOSTNAME=network-as-code.p-eu.rapidapi.com
# NAC_QOD_RAPIDAPI_HOST=network-as-code.nokia.rapidapi.com
# QOD_ADDITIONAL_DURATION=60
